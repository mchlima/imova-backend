# Conexão PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/imova?schema=public"

# Auth
JWT_SECRET="troque-por-um-segredo-forte"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
# Origem do frontend Nuxt (para CORS com cookies)
CORS_ORIGIN="http://localhost:3100"
# Cookie de sessão em HTTPS (true em produção)
COOKIE_SECURE=false

# Cloudflare R2 (imagens de capa) — bucket imova-public
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="imova-public"
# URL pública do bucket (R2.dev ou domínio custom), sem barra no fim
R2_PUBLIC_BASE="https://pub-xxxxxxxx.r2.dev"
